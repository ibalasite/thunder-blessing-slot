# Thunder Blessing Slot — Next.js API Server
# Copy to .env.local for local development

NODE_ENV=development
PORT=3001

# Supabase (LOCAL: from `supabase start` output)
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-start

# JWT (must be ≥ 32 chars)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-characters
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Upstash Redis (optional — NullCacheAdapter used if absent)
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Rate limiting
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=900

# Session limit per user (S-07)
MAX_SESSIONS_PER_USER=5

# Admin IP allowlist (S-12) — comma-separated, empty = no restriction
ADMIN_ALLOWED_IPS=
