{
  "name": "thunder-blessing-slot",
  "version": "1.0.0",
  "description": "Thunder Blessing Slot — mono-repo root (Cocos game + Next.js API)",
  "private": true,
  "main": "main.js",
  "scripts": {
    "test": "jest",
    "test:unit": "jest --testPathPatterns=unit",
    "test:integration": "jest --testPathPatterns=integration",
    "test:e2e": "jest --testPathPatterns=e2e",
    "test:coverage": "jest --coverage",
    "deploy": "gh-pages --dotfiles --dist build/web-desktop",
    "web": "pnpm --filter @thunder/web dev",
    "web:build": "pnpm --filter @thunder/web build",
    "web:test": "pnpm --filter @thunder/web test",
    "worker:dev": "pnpm --filter @thunder/worker dev"
  },
  "engines": {
    "cocos-creator": "3.8.0",
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "creator": {
    "version": "3.8.7",
    "dependencies": {}
  },
  "uuid": "1c530a7b-fff7-4a76-ac4b-51192b1d058c",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "gh-pages": "^6.3.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6"
  }
}
